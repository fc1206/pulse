    "label": "breadth",
    "low": "point solution",
    "high": "full suite"
  },
  "y_axis": {
    "label": "autonomy",
    "low": "informs",
    "high": "does the work"
  },
  "x_cluster_base": {
    "incumbent": 70,
    "direct": 60,
    "adjacent": 50,
    "substitute": 45,
    "infra": 40,
    "vertical": 30
  },
  "x_default_base": 45,
  "x_up": {
    "platform|suite|all[- ]in[- ]one|end[- ]to[- ]end|full[- ]stack": 12,
    "integrat|connectors?|plugs? into|works with .{0,20}tools": 10,
    "\\b(50|100|150|200|400|1000)\\+? (integrations|connectors|tools|sources)": 9,
    "enterprise[- ]wide|org(anization)?[- ]wide|across (the )?(entire )?(company|org|business)": 8
  },
  "x_down": {
